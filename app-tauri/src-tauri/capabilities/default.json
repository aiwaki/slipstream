{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Slipstream tray capabilities",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "process:default",
    "updater:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/geph5-client", "sidecar": true, "args": ["--config", { "validator": ".+" }] }]
    }
  ]
}
