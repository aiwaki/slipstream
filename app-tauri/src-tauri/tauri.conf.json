{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slipstream",
  "version": "0.1.0",
  "identifier": "dev.slipstream.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "resources": ["icons/*.png"],
    "externalBin": ["binaries/geph5-client"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OWNER/slipstream/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNING_PUBLIC_KEY",
      "windows": { "installMode": "passive" }
    }
  }
}
