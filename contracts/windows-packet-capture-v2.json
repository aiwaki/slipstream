{
  "schema_version": 1,
  "contract": "slipstream.windows_packet_capture",
  "contract_version": 2,
  "invariants": {
    "capture_only": true,
    "exact_route_may_widen_capture_only": true,
    "backend_authorization": false,
    "per_flow_reclassification_required": true,
    "hostname_evidence_is_in_band": true,
    "opaque_hostname_is_direct_passthrough": true,
    "direct_policy_is_direct_passthrough": true,
    "capture_generation_required": true,
    "flow_identity_required": true,
    "maximum_evidence_lifetime_ms": 5000,
    "native_dll_loading": false,
    "native_adapter_creation": false,
    "native_route_effect": false,
    "default_route_mutation": false,
    "system_dns_mutation": false,
    "proxy_pac_vpn_mutation": false,
    "production_service_host_composition": false
  },
  "native_effect_gates": {
    "outbound_loop_avoidance": "required",
    "pre_existing_flow_activation_safety": "required",
    "bounded_capture_expiry_and_removal": "required",
    "crash_safe_rollback": "required",
    "external_vpn_coexistence": "required",
    "disposable_amd64_qualification": "required",
    "disposable_arm64_qualification": "required"
  },
  "vectors": [
    {
      "name": "discord-tls-is-local-bypass-policy-only",
      "now_ms": 1200,
      "observation": {
        "capture_generation": 7,
        "flow_id": 41,
        "transport": "tcp_tls",
        "destination": "104.16.58.5",
        "observed_at_ms": 1000,
        "expires_at_ms": 5000,
        "attribution": {
          "kind": "hostname",
          "source": "tls_client_hello_sni",
          "host": "gateway.discord.gg"
        }
      },
      "expected": {
        "disposition": "policy_classified",
        "route_class": "local_bypass",
        "service_group": "discord",
        "normalized_host": "gateway.discord.gg"
      }
    },
