      "identity": "v1",
      "lifecycle": "running_active",
      "payload": "exact",
      "observation": "owned_running",
      "expected": { "outcome": "no_change", "reason": "already_satisfied" }
    },
    {
      "name": "start-cannot-override-absent-intent",
      "action": "start_owned_service",
      "identity": "v1",
      "lifecycle": "absent_owned_active",
      "payload": "exact",
      "observation": "owned_stopped",
      "expected": { "outcome": "refuse", "reason": "intent_mismatch" }
    },
    {
      "name": "start-refuses-foreign-service",
      "action": "start_owned_service",
      "identity": "v1",
      "lifecycle": "running_active",
      "payload": "exact",
      "observation": "foreign_stopped",
      "expected": { "outcome": "refuse", "reason": "service_not_owned" }
