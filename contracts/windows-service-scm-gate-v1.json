  "vectors": [
    {
      "name": "register-exact-absent-service",
      "action": "register_service",
      "identity": "v1",
      "lifecycle": "install_running",
      "payload": "exact",
      "observation": "absent",
      "expected": { "outcome": "mutate", "reason": "authorized" }
    },
    {
      "name": "register-refuses-existing-active-install",
      "action": "register_service",
      "identity": "v1",
      "lifecycle": "running_active",
      "payload": "exact",
      "observation": "absent",
      "expected": { "outcome": "refuse", "reason": "active_install_mismatch" }
    },
    {
      "name": "register-refuses-present-service",
      "action": "register_service",
      "identity": "v1",
      "lifecycle": "install_running",
      "payload": "exact",
