{
  "schema_version": 1,
  "contract": "slipstream.windows_packet_egress",
  "contract_version": 1,
  "invariants": {
    "pure_admission_only": true,
    "pre_capture_route_evidence_required": true,
    "capture_generation_bound": true,
    "route_epoch_bound": true,
    "luid_and_live_index_bound": true,
    "capture_interface_rejected": true,
    "ipv4_unicast_interface_value_is_network_order": true,
    "ipv6_unicast_interface_value_is_host_order": true,
    "external_vpn_interface_type_is_not_rewritten": true,
    "backend_selection": false,
    "native_route_query": false,
    "native_socket_effect": false,
    "native_adapter_effect": false,
    "native_route_effect": false,
    "default_route_mutation": false,
    "system_dns_mutation": false,
    "proxy_pac_vpn_mutation": false,
    "production_service_host_composition": false,
    "maximum_evidence_lifetime_ms": 5000
  },
  "remaining_native_gates": {
    "trusted_route_collector": "required",
    "live_luid_to_index_revalidation": "required",
    "actual_ipv4_socket_binding": "required",
    "actual_ipv6_socket_binding": "required",
    "competing_capture_route_qualification": "required",
    "pre_existing_flow_activation_safety": "required",
    "bounded_capture_expiry_and_removal": "required",
    "external_vpn_coexistence": "required",
    "disposable_amd64_qualification": "required",
    "disposable_arm64_qualification": "required"
  },
  "vectors": [
    {
      "name": "ipv4-system-egress-is-generation-and-route-bound",
      "request": {
        "capture_generation": 7,
        "flow_id": 41,
        "destination": "104.16.58.5",
        "capture_started_at_ms": 1100,
        "now_ms": 1200,
        "current_route_epoch": 9,
        "current_capture_interface": { "luid": 900, "index": 90 },
        "current_egress_interface": { "luid": 120, "index": 12 },
        "baseline": {
          "capture_generation": 7,
          "route_epoch": 9,
          "destination": "104.16.58.5",
          "observed_at_ms": 1000,
          "expires_at_ms": 5000,
          "capture_interface": { "luid": 900, "index": 90 },
          "egress_interface": { "luid": 120, "index": 12 },
          "source_address": "10.0.0.4",
          "route_prefix": "0.0.0.0/0",
          "route_is_loopback": false
        }
      },
      "expected": {
        "result": "plan",
        "destination": "104.16.58.5",
        "source_address": "10.0.0.4",
        "egress_luid": 120,
        "egress_index": 12,
        "binding_kind": "ipv4_network_byte_order",
        "binding_value": 201326592
      }
    },
