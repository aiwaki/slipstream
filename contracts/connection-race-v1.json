{
  "schema_version": 1,
  "contract": "slipstream.connection_race",
  "contract_version": 1,
  "invariants": {
    "circuit_gate_before_resolver": true,
    "circuit_accounting": "one_result_per_logical_request",
    "connector_completion_at_deadline_precedes_timer": true,
    "adapters": "scripted_only",
    "network_io": false
  },
  "race_config": {
    "timeout_ms": 1000,
    "stagger_ms": 250,
    "max_concurrent": 2,
    "preferred_family": "ipv6"
  },
  "circuit_config": {
    "failure_threshold": 2,
    "open_duration_ms": 1000,
    "half_open_max_in_flight": 1,
    "success_threshold": 1
  },
  "vectors": [
    {
      "name": "ipv6-stall-falls-back-to-ipv4-after-stagger",
      "requests": [
        {
          "started_at_ms": 0,
          "key": {
            "service_group": "generic",
            "route_class": "direct_passthrough",
            "backend_id": "direct"
          },
          "resolver": {
            "outcome": "success",
            "delay_ms": 10,
            "candidates": [
              {
                "id": "v6-a",
                "family": "ipv6",
                "address": "2001:db8::10",
                "source": "fake-resolver",
                "expires_at_ms": null
              },
              {
                "id": "v4-a",
                "family": "ipv4",
                "address": "192.0.2.10",
                "source": "fake-resolver",
                "expires_at_ms": null
              }
            ]
          },
          "connector": {
            "v6-a": {"outcome": "stall", "delay_ms": 0},
            "v4-a": {"outcome": "success", "delay_ms": 50}
          }
        }
      ],
      "expected_requests": [
        {
          "phase": "connected",
          "reason": "connected",
          "winner_candidate_id": "v4-a",
          "completed_at_ms": 310,
          "resolver_calls": 1,
          "starts": ["v6-a@10", "v4-a@260"],
          "cancelled": ["v6-a"],
          "attempts": [
            "v6-a:cancelled:10:310",
            "v4-a:succeeded:260:310"
          ],
          "circuit_decisions": [
            "allow:closed:closed",
            "record:success_recorded:closed"
          ]
        }
      ],
      "expected_circuit_states": []
    },
