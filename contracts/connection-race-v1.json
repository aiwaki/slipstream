          "resolver_calls": 1,
          "starts": ["v6-a@0", "v4-a@40"],
          "cancelled": [],
          "attempts": [
            "v6-a:failed:0:40",
            "v4-a:failed:40:100"
          ],
          "circuit_decisions": [
            "allow:closed:closed",
            "record:failure_recorded:closed"
          ]
        }
