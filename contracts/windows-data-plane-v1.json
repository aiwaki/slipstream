{
  "schema_version": 1,
  "contract": "slipstream.windows_data_plane",
  "contract_version": 1,
  "invariants": {
    "network_effects": false,
    "native_api_effects": false,
    "external_dns_proxy_pac_vpn_read_only": true,
    "protected_local_bypass_never_uses_geph": true,
    "first_payload_deadline_does_not_end_relaying_sessions": true,
    "partial_payload_failure_is_stream_failure": true,
    "caller_and_shutdown_cancellation_are_not_backend_failures": true,
    "resources_close_exactly_once_before_outcome": true,
    "late_completion_cannot_resurrect_terminal_session": true,
    "shutdown_is_bounded": true,
    "terminal_history_is_bounded_and_aba_safe": true
  },
  "config": {
    "max_active_sessions": 4,
    "max_retained_terminal_sessions": 2,
    "cancel_timeout_ms": 50,
    "shutdown_timeout_ms": 100
  },
  "vectors": [
