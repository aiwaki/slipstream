        {"kind": "worker_ready", "now_ms": 2}
      ],
      "expected": {
        "worker_phase": "ready",
        "sessions": [],
        "open_resources": [],
        "effects": [
          "reject:early:worker_not_ready",
          "worker_ready"
        ],
        "outcomes": []
      }
    },
